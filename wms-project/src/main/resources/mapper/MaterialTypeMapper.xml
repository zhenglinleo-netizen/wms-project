<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.wms.mapper.MaterialTypeMapper">

    <resultMap id="BaseResultMap" type="com.example.wms.entity.MaterialType">
        <id column="id" property="id"/>
        <result column="type_name" property="typeName"/>
        <result column="description" property="description"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByName" resultMap="BaseResultMap">
        SELECT id, type_name, description, create_time
        FROM material_type
        WHERE type_name = #{typeName}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO material_type (type_name, description, create_time)
        VALUES (#{typeName}, #{description}, NOW())
    </insert>

</mapper>